DATABASE_URL=postgresql://pixii:pixii@localhost:5432/amazon_analytics
# Include both hostnames if you open Next on localhost or 127.0.0.1 (they differ for CORS).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# mock | scraperapi
SCRAPING_PROVIDER=mock
SCRAPING_API_KEY=
# Render JS-heavy Amazon pages via ScraperAPI (adds latency/credits)
SCRAPERAPI_RENDER=false
# Optional: force proxy country (e.g. uk, us). If empty, inferred from AMAZON_DOMAIN.
SCRAPERAPI_COUNTRY_CODE=
# Save HTML under backend/var/debug_scraperapi/ when a parse looks empty (for selector tuning)
SCRAPERAPI_SAVE_HTML_ON_EMPTY=false
AMAZON_DOMAIN=amazon.com

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

MAX_REVIEWS_PER_ASIN=1000
REVIEW_BATCH_MAP_SIZE=100

# Apify (optional): 90-day price history for the primary ASIN of competitive jobs.
# Both keys must be set for the feature to activate; leave empty to disable.
# Token: https://console.apify.com/account/integrations
APIFY_API_TOKEN=
# Actor slug in <user>~<actor-name> form, copied from your actor's page in console.apify.com.
APIFY_PRICE_HISTORY_ACTOR=
# APIFY_TIMEOUT_SECONDS=90
# PRICE_HISTORY_DAYS=90
